version: "3.9"

networks:
  resilience_net:
    driver: bridge

volumes:
  rabbitmq_data:
  elastic_data:
  postgres_data:

services:

  # =========================
  # Infraestructura base
  # =========================

  rabbitmq:
    image: rabbitmq:3.12-management
    container_name: rabbitmq
    ports:
      - "5672:5672"
      - "15672:15672"
    volumes:
      - rabbitmq_data:/var/lib/rabbitmq
    networks:
      - resilience_net

  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.11.1
    container_name: elasticsearch
    environment:
      - discovery.type=single-node
      - xpack.security.enabled=false
      - ES_JAVA_OPTS=-Xms512m -Xmx512m
    ports:
      - "9200:9200"
    volumes:
      - elastic_data:/usr/share/elasticsearch/data
    networks:
      - resilience_net

  postgres:
    image: postgres:15
    container_name: postgres
    environment:
      POSTGRES_DB: resilience
      POSTGRES_USER: resilience_user
      POSTGRES_PASSWORD: resilience_pass
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - resilience_net

  # =========================
  # Model services
  # =========================

  observability:
    build: ./observability
    container_name: observability
    environment:
      RABBITMQ_HOST: rabbitmq
      ELASTICSEARCH_HOST: http://elasticsearch:9200
    depends_on:
      - rabbitmq
      - elasticsearch
    networks:
      - resilience_net

  failure_detector:
    build: ./failure_detector
    container_name: failure_detector
    environment:
      RABBITMQ_HOST: rabbitmq
      ELASTICSEARCH_HOST: http://elasticsearch:9200
    depends_on:
      - rabbitmq
      - observability
    networks:
      - resilience_net

  failure_classifier:
    build: ./failure_classifier
    container_name: failure_classifier
    environment:
      RABBITMQ_HOST: rabbitmq
      ELASTICSEARCH_HOST: http://elasticsearch:9200
    depends_on:
      - rabbitmq
      - failure_detector
    networks:
      - resilience_net

  impact_evaluator:
    build: ./impact_evaluator
    container_name: impact_evaluator
    environment:
      RABBITMQ_HOST: rabbitmq
      ELASTICSEARCH_HOST: http://elasticsearch:9200
    depends_on:
      - rabbitmq
      - failure_classifier
    networks:
      - resilience_net

  decision_engine:
    build: ./decision_engine
    container_name: decision_engine
    environment:
      RABBITMQ_HOST: rabbitmq
      RULES_SERVICE_URL: http://rules_manager:8000
      ELASTICSEARCH_HOST: http://elasticsearch:9200
    depends_on:
      - rabbitmq
      - rules_manager
      - impact_evaluator
    networks:
      - resilience_net

  rules_manager:
    build: ./rules_manager
    container_name: rules_manager
    ports:
      - "8000:8000"
    environment:
      RULES_FILE: /app/rules.json
    volumes:
      - ./rules_manager/rules.json:/app/rules.json
    networks:
      - resilience_net

  failure_solver:
    build: ./failure_solver
    container_name: failure_solver
    environment:
      RABBITMQ_HOST: rabbitmq
      ELASTICSEARCH_HOST: http://elasticsearch:9200
      POSTGRES_HOST: postgres
      POSTGRES_DB: resilience
      POSTGRES_USER: resilience_user
      POSTGRES_PASSWORD: resilience_pass
    depends_on:
      - rabbitmq
      - postgres
      - decision_engine
    networks:
      - resilience_net

  event_registry:
    build: ./event_registry
    container_name: event_registry
    environment:
      POSTGRES_HOST: postgres
      POSTGRES_DB: resilience
      POSTGRES_USER: resilience_user
      POSTGRES_PASSWORD: resilience_pass
    depends_on:
      - postgres
    networks:
      - resilience_net

  # =========================
  # Simulador de Pipeline CI/CD
  # =========================

  pipeline_simulator:
    build: ./pipeline_simulator
    container_name: pipeline_simulator
    environment:
      RABBITMQ_HOST: rabbitmq
    depends_on:
      - rabbitmq
      - observability
    networks:
      - resilience_net
`