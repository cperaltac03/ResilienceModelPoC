[
  {
    "if": {
      "category": "Timeout"
    },
    "then": {
      "action": "increase_timeout_and_retry",
      "max_attempts": 3,
      "backoff_seconds": 5
    }
  },
  {
    "if": {
      "category": "Connection lost"
    },
    "then": {
      "action": "change_mirror_and_retry",
      "max_attempts": 2,
      "backoff_seconds": 3
    }
  },
  {
    "if": {
      "category": "404"
    },
    "then": {
      "action": "validate_dependency_and_fallback"
    }
  },
  {
    "if": {
      "category": "Version conflict"
    },
    "then": {
      "action": "finalize_pipeline"
    }
  },
  {
    "if": {
      "category": "Checksum mismatch"
    },
    "then": {
      "action": "clean_cache_and_retry",
      "max_attempts": 1,
      "backoff_seconds": 2
    }
  }
]